{
  "name": "fude-workspace",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "examples/*",
    "docs"
  ],
  "scripts": {
    "build": "bun run --filter @tigerabrodioss/fude build",
    "format": "prettier --write .",
    "lint": "eslint ."
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "@tigerabrodioss/fude": "workspace:*",
    "globals": "^16.0.0",
    "happy-dom": "^20.8.3",
    "prettier": "^3.4.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0"
  }
}
